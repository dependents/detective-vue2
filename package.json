{
  "name": "detective-vue2",
  "version": "3.0.0",
  "author": "Havunen <sampo.kivisto@live.fi>",
  "description": "Get the dependencies of a Vue module",
  "type": "module",
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "index.js"
  ],
  "scripts": {
    "lint": "xo",
    "fix": "xo --fix",
    "vitest": "vitest",
    "test": "npm run lint && vitest run",
    "test:ci": "vitest run --coverage",
    "watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dependents/detective-vue2.git"
  },
  "keywords": [
    "detective",
    "dependencies",
    "module",
    "ast",
    "import",
    "vue"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dependents/detective-vue2/issues"
  },
  "homepage": "https://github.com/dependents/detective-vue2",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "peerDependencies": {
    "typescript": "^5.4.4 || ^6.0.2"
  },
  "dependencies": {
    "@dependents/detective-less": "^6.0.0",
    "@vue/compiler-sfc": "^3.5.34",
    "detective-es6": "^6.0.0",
    "detective-sass": "^7.0.0",
    "detective-scss": "^6.0.0",
    "detective-stylus": "^6.0.0",
    "detective-typescript": "^15.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "xo": "^2.0.2"
  }
}
